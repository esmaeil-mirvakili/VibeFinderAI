# VibeFinder AI environment example
#
# Copy this file to `.env` if you want Gemini local overrides. The Streamlit app
# auto-loads `.env` from the project root on startup without overriding
# variables that are already exported in your shell.


# ---------------------------------------------------------------------------
# Dataset
# ---------------------------------------------------------------------------

# Optional path to the Kaggle dataset CSV or to a directory containing the CSV.
# If unset, the app defaults to the project root (`.`) and expects or creates
# `spotify_songs.csv` there through the dataset download helper.
#
# Examples:
# VIBEFINDER_DATA_PATH=.
# VIBEFINDER_DATA_PATH=./spotify_songs.csv
# VIBEFINDER_DATA_PATH=/absolute/path/to/dataset/folder
VIBEFINDER_DATA_PATH=.


# ---------------------------------------------------------------------------
# Lyric Embeddings and FAISS RAG Index
# ---------------------------------------------------------------------------

# SentenceTransformers model used to embed both dataset lyrics and user lyric
# queries. The model name is stored in `lyric_faiss_metadata.json`; if you
# change this value, the app will rebuild the lyric FAISS index on startup.
VIBEFINDER_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Batch size for embedding dataset lyrics while building the FAISS index.
# This affects app startup when the index is missing and also
# scripts/setup_dataset_index.py. Increase this on machines with more
# memory/GPU capacity. Decrease it if index generation runs out of memory.
VIBEFINDER_EMBEDDING_BATCH_SIZE=32

# Optional device override passed to SentenceTransformers.
# This affects app startup and scripts/setup_dataset_index.py.
# Common values: cpu, cuda, mps.
# Leave blank to let SentenceTransformers choose the default device.
VIBEFINDER_EMBEDDING_DEVICE=


# ---------------------------------------------------------------------------
# LLM Agent Settings
# ---------------------------------------------------------------------------

# LLM provider selection.
# Default: gemini.
# Values: gemini, openai, ollama, local, self_hosted.
VIBEFINDER_LLM_PROVIDER=gemini

# Model name for the selected LLM provider. Gemini is the default hosted
# backend for the agent layer.
# VIBEFINDER_LLM_MODEL=gemma-4-31b-it
# VIBEFINDER_LLM_MODEL=gemma-4-26b-a4b-it
VIBEFINDER_LLM_MODEL=gemini-2.5-flash

# LLM request timeout in seconds.
VIBEFINDER_LLM_TIMEOUT_SECONDS=600

# LLM sampling temperature. Keep this low for reproducible structured outputs.
VIBEFINDER_LLM_TEMPERATURE=0

# Gemini API key for Google AI Studio / Gemini API. Keep real keys only in
# `.env`, never in `.env.example`.
GEMINI_API_KEY=

# Some Google SDKs and deployment environments use GOOGLE_API_KEY instead of
# GEMINI_API_KEY. Set one or both depending on the selected client adapter.
GOOGLE_API_KEY=

# OpenAI-compatible provider settings. OPENAI_API_KEY is required when
# VIBEFINDER_LLM_PROVIDER=openai. For local/self-hosted OpenAI-compatible
# servers, the API key is optional unless your server requires one.
# OPENAI_API_KEY=

# Optional base URL for local or self-hosted OpenAI-compatible APIs.
# Defaults to https://api.openai.com/v1 for openai/local/self_hosted.
# Examples:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_BASE_URL=http://localhost:8000/v1

# Optional Ollama base URL. Used only when VIBEFINDER_LLM_PROVIDER=ollama.
# OLLAMA_BASE_URL=http://localhost:11434


# ---------------------------------------------------------------------------
# LangSmith Tracing
# ---------------------------------------------------------------------------

# Set both tracing flags to true and provide LANGSMITH_API_KEY to inspect graph
# runs, agent nodes, tool calls, retries, and final outputs in LangSmith.
LANGSMITH_TRACING=true
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=
VIBEFINDER_LANGSMITH_PROJECT=
LANGSMITH_PROJECT=


# ---------------------------------------------------------------------------
# Internal Runtime Notes
# ---------------------------------------------------------------------------

# The app sets VIBEFINDER_FILE_LOGGING_CONFIGURED internally to avoid duplicate
# log handlers during Streamlit reruns. Do not set it manually in normal use.
# VIBEFINDER_FILE_LOGGING_CONFIGURED=
